# Clave de API para Gemini
VITE_GEMINI_API_KEY=

# Prompt base para sugerencias de tareas
VITE_GEMINI_TASK_PROMPT=Eres un asistente de productividad. Basándote en el estado de ánimo y las tareas pendientes, sugiere cuál debería realizar el usuario a continuación.

# Prompt base para reescritura del diario
VITE_GEMINI_JOURNAL_PROMPT=Reescribe el siguiente texto del diario en un lenguaje más natural.
