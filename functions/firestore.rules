rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Reglas para billing-items
    match /billing-items/{itemId} {
      // Permitir lectura solo al usuario autenticado
      allow read: if request.auth != null &&
                     (resource.data.userId == request.auth.uid || !exists(/databases/$(database)/documents/billing-items/$(itemId)));

      // Permitir escritura solo al usuario autenticado
      allow create: if request.auth != null &&
                       request.resource.data.userId == request.auth.uid;

      allow update: if request.auth != null &&
                       resource.data.userId == request.auth.uid;

      allow delete: if request.auth != null &&
                       resource.data.userId == request.auth.uid;
    }

    // Regla general para otras colecciones (ajustar según necesidades)
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
